#!/usr/bin/env bash

APP_NAME="$( basename -- "${0}" )"
VERSION="1.1.0"

function fz::kill()
{
	local signal="${1:--SIGTERM}"

	[[ "${signal}" == -* ]] || signal="-${signal}"
	ps aux | fzf --exact --header-lines=1 --prompt="kill ${signal} > " --select-1 --tac | awk '{ print $2 }' | xargs -I {} kill "${signal}" {}
}

function fz::man()
{
	# shellcheck disable=SC2016     # SC2016: Expressions don't expand in single quotes, use double quotes for that.
	local fzfPreview='awk '\''{ gsub( /[ (),]/, " " ) ; print $2, $1 }'\'' <<< {} | xargs man'
	local binBatcat=""

	binBatcat="$( command -v batcat || command -v bat )"

	[[ -n "${binBatcat}" ]] && \
		fzfPreview+=' | sh -c "col -bx | '"${binBatcat}"' --color=always --language=man --paging=never --style=plain"'

	man -k . 2>/dev/null \
		| fzf --preview="${fzfPreview}" --preview-window="right:70%" --prompt="man > " --query="^${*}" --reverse --select-1 \
		| awk '{ gsub( /[ (),]/, " " ) ; print $2, $1 }' \
		| xargs -I {} printf "man %s\n" {} \
		| sh
}

function fz::ssh()
{
	shopt -s nullglob

	local fSshConfig=( /etc/ssh/ssh_config "${HOME}"/.ssh/config "${HOME}"/.ssh/config.d/* )
	local discoveredHosts=""
	local sshServer=""

	# shellcheck disable=SC2207     # SC2207: Prefer `mapfile` or `read -a` to split command output (or quote to avoid splitting).
	fSshConfig+=( $( awk '/^[[:space:]]*Include[[:space:]]+/ { print $2 }' "${fSshConfig[@]}" 2>/dev/null ) )

	# shellcheck disable=SC2046     # SC2046: Quote this to prevent word splitting.
	discoveredHosts=$( \
		awk '$1=="Host" { for( i = 2 ; i <= NF ; i++ ) if( $i !~ /\*/ ) print $i }' $( for fp in "${fSshConfig[@]}" ; do [[ -f "${fp}" ]] && printf "%q " "${fp}" ; done ) ; \
		awk '/^[^|]/ { split( $1, h, "," ) ; for( i in h ){ gsub( /^\[|\](:[0-9]+)?$/, "", h[i] ) ; print h[i] } }' "${HOME}"/.ssh/known_hosts 2>/dev/null \
	)

	sshServer="$( printf "%s\n" "${discoveredHosts}" | sort -u | fzf --height=6 --preview="ssh -G -T {} | head -n 4 | column -t" --prompt="ssh > " --reverse --select-1 )"

	# shellcheck disable=SC2029     # SC2029: Note that, unescaped, this expands on the client side.
	if [[ -n "${sshServer}" ]] ; then ssh "${@}" "${sshServer}" ; fi
}

command -v tmux &>/dev/null && function fz::tmux()
{
	local selection=""
	local key=""
	local selectedType=""
	local selectedTarget=""

	selection="$( {
			tmux list-sessions -F "session #S _ #{session_windows}w"
			tmux list-windows -a -F "window #S:#I #W #{window_panes}p"
			tmux list-panes -a -F "pane #S:#I.#P #{pane_current_command}"
		} \
		| column -t | fzf --expect="enter,ctrl-k" --header=$'\n[ Enter ] ..... attach / switch\n[ Ctrl + k ] .. kill\n\n' --prompt="tmux > " --reverse --select-1 --tmux | xargs printf "%q "
	)"

	[[ -z "${selection}" ]] && return 0

	key="$( awk '{ print $1 }' <<< "${selection}" )"
	selectedType="$( awk '{ print $2 }' <<< "${selection}" )"
	selectedTarget="$( awk '{ print $3 }' <<< "${selection}" )"

	if [[ "${key}" == "enter" ]] ; then

		case "${selectedType}" in
			session) if [[ -n "${TMUX}" ]]; then tmux switch-client -t "${selectedTarget}" ; else tmux attach -t "${selectedTarget}" ; fi ;;
			window) if [[ -n "${TMUX}" ]]; then tmux select-window -t "${selectedTarget}" ; else tmux attach -t "${selectedTarget%%:*}" ';' select-window -t "${selectedTarget}" ; fi ;;
			pane) if [[ -n "${TMUX}" ]]; then tmux select-window -t "${selectedTarget}" ';' select-pane -t "${selectedTarget}" ; else tmux attach -t "${selectedTarget%%:*}" ';' select-pane -t "${selectedTarget}" ; fi ;;
		esac

	elif [[ "${key}" == "ctrl-k" ]] ; then

		case "${selectedType}" in
			session) tmux kill-session -t "${selectedTarget}" ;;
			window) tmux kill-window -t "${selectedTarget}" ;;
			pane) tmux kill-pane -t "${selectedTarget}" ;;
		esac
	fi
}

function __fz::help()
{
	__fz::version

	cat <<- HEREDOC

	Pipe commands to FZF.

	Usage: ${APP_NAME} [COMMAND] [arguments for COMMAND]
	       ${APP_NAME} [OPTION]

	Commands:

	$( compgen -A function "fz::" | sed "s/^fz::/    /" )

	Options:

	    -h, --help                display this help
	    -V, --version             output version information
	HEREDOC
}

function __fz::main()
{
	local arg="${1:---help}"

	command -v fzf &>/dev/null || {
		printf "%s\n" "[${APP_NAME} error]: Install \"fzf\" to use ${APP_NAME}."
		return 1
	}

	case "${arg}" in
		-V|--version)
			__fz::version
			return 0
		;;

		-h|--help)
			__fz::help
			return 0
		;;

		*)
			if [[ "$( type -t "fz::${arg}" )" != "function" ]] ; then
				printf "%s\n" "[${APP_NAME} error]: Found argument \"${arg}\" which wasn't expected. Try --help."
				return 1
			fi

			shift
			fz::"${arg}" "${@}"
			return "${?}"
		;;
	esac
}

function __fz::version() { printf "%s\n" "${APP_NAME} ${VERSION}" ; }

__fz::main "${@}"
